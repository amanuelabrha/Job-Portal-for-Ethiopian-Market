# --- Database ---
POSTGRES_USER=jobportal
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=jobportal_et
DATABASE_URL=postgresql://jobportal:change_me_strong@localhost:5432/jobportal_et

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (generate: openssl rand -hex 32) ---
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_secret
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# --- App ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
TZ=Africa/Addis_Ababa

# --- Google OAuth (Web client) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (SendGrid or SMTP) ---
EMAIL_FROM=noreply@yourdomain.et
SENDGRID_API_KEY=
# Ethiopian / generic SMTP (optional if not using SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- SMS (Africa's Talking or Ethio Telecom when available) ---
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=JobET

# --- File storage ---
# local | s3 | cloudinary
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=af-south-1
CLOUDINARY_URL=

# --- Payments (Chapa / Telebirr placeholders — wire in production) ---
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
TELEBIRR_MERCHANT_ID=

# --- CV parsing ---
# basic | spacy (requires: pip install spacy && python -m spacy download en_core_web_sm)
CV_PARSER_MODE=basic
AFFINDA_API_KEY=

# --- Security ---
# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_MB=5

# Optional: ClamAV socket for malware scan (empty = skip scan in dev)
CLAMAV_SOCKET=
